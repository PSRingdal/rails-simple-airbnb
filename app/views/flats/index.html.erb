<nav class="nav-bar">
  <%= link_to "Simple Airbnb", flats_path, class: "home"  %>
  <%= link_to "Add Flat",new_flat_path, class: "btn btn-primary" %>
</nav>
<h1>All our flats (<%= Flat.count %>)</h1>
<div class="cards">
<% @flats.each do |flat|%>
  <div class="card">
    <h1><%= flat.name %></h1>
    <p><%= flat.address %></p>
    <div class="number">
      <p><%= flat.number_of_guests %></p>
      <p>£<%= flat.price_per_night %></p>
    </div>
    <div class="info">
      <%= link_to "More info", flat_path(flat), class: "more-info" %>
      <%= link_to "Edit", edit_flat_path(flat), class: "edit" %>
      <%= link_to "Remove", flat_path(flat), class: "remove",
      data: {turbo_method: :delete, turbo_confirm: "Are you sure?"} %>
    </div>
  </div>
  <% end %>
</div>
